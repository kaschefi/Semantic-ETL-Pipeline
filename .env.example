# ==========================================
# Semantic ETL Pipeline Configuration Blueprint
# ==========================================

# Server & CORS Settings
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["*"]

# Pinecone Vector Credentials
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=semantic-etl-index

# Ollama Service Configuration
# Use http://host.docker.internal:11434 when running inside Docker on host machine
OLLAMA_HOST=http://host.docker.internal:11434
EMBEDDING_MODEL=mxbai-embed-large
TEXT_MODEL=llama3
VISION_MODEL=llava

# Groq Cloud AI Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_VISION_MODEL=qwen/qwen3.6-27b

# Pipeline Processing & Chunking Parameters
MAX_CHUNK_CHARS=1200
OVERLAP_ELEMENTS=1
